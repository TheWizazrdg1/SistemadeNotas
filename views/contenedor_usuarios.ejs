<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestor de Usuarios</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <style>
        nav {
            background: linear-gradient(#04144a 100%);
        }

        .modal h4 {
            color: #2196F3;
        }

        .table-container {
            max-height: 60vh;
            overflow: auto;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }

        thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
            color: white;
        }
    </style>
</head>

<body class="grey lighten-4">
    <nav>
        <div class="nav-wrapper container">
            <a href="#" class="brand-logo left hide-on-small-only" style="font-size: 1.5rem;">
                <i class="material-icons left">group</i>Gestor de Usuarios
            </a>
            <ul id="nav-mobile" class="right">
                <li><a href="/configuracion-global"><i class="material-icons left">arrow_back</i>Volver</a></li>
            </ul>
        </div>
    </nav>

    <div class="container" style="margin-top: 20px; width: 95%; max-width: 1200px;">
        <div class="card-panel z-depth-2">
            <h5 class="center-align" style="color: #495057; font-weight: 600;">➕ Registrar Nuevo Usuario</h5>
            <form action="/crear_usuario" method="POST" class="row" style="margin-bottom: 0;">
                <div class="input-field col s12 m6 l3">
                    <i class="material-icons prefix">person</i>
                    <input id="username" name="username" type="text" class="validate" required>
                    <label for="username">Nombre de Usuario</label>
                </div>

                <div class="input-field col s12 m6 l3">
                    <i class="material-icons prefix">lock</i>
                    <input id="password" name="password" type="password" class="validate" required>
                    <label for="password">Contraseña</label>
                </div>

                <div class="input-field col s12 m6 l3">
                    <i class="material-icons prefix">assignment_ind</i>
                    <select name="rol" required>
                        <option value="" disabled selected>Selecciona un rol</option>
                        <option value="superadmin">Super Administrador</option>
                        <option value="admin">Administrador</option>
                        <option value="profesor">Profesor / Docente</option>
                    </select>
                    <label>Asignar Rol</label>
                </div>

                <div class="input-field col s12 m6 l3 center-align">
                    <button class="btn waves-effect waves-light blue darken-2" type="submit" style="width: 100%; height: 45px; border-radius: 20px;">
                        Crear Usuario
                        <i class="material-icons right">add_circle</i>
                    </button>
                </div>
            </form>
        </div>

        <div class="card table-container z-depth-2">
            <table class="highlight centered striped">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre de Usuario</th>
                        <th>Rol</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (usuarios && usuarios.length > 0) { %>
                        <% usuarios.forEach(u => { %>
                            <tr>
                                <td style="font-weight: bold;"><%= u.id_usuario %></td>
                                <td><%= u.username %></td>
                                <td>
                                    <% if (u.rol === 'superadmin') { %>
                                        <span class="new badge red" data-badge-caption="SuperAdmin"></span>
                                    <% } else if (u.rol === 'admin') { %>
                                        <span class="new badge blue" data-badge-caption="Admin"></span>
                                    <% } else { %>
                                        <span class="new badge green" data-badge-caption="<%= u.rol.charAt(0).toUpperCase() + u.rol.slice(1) %>"></span>
                                    <% } %>
                                </td>
                                <td>
                                    <a href="#modalEdicionUsuario" class="btn-small amber darken-2 modal-trigger waves-effect waves-light" onclick="cargarUsuario('<%= u.id_usuario %>', '<%= u.username %>', '<%= u.rol %>')">
                                        <i class="material-icons">edit</i>
                                    </a>
                                    <a href="/borrar_usuario/<%= u.id_usuario %>" class="btn-small red darken-2 waves-effect waves-light" onclick="return confirm('¿Seguro que deseas eliminar definitivamente al usuario <%= u.username %>?');">
                                        <i class="material-icons">delete</i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="grey-text center-align" style="padding: 20px;">
                                No hay usuarios registrados o disponibles en el sistema.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Editar Usuario -->
    <div id="modalEdicionUsuario" class="modal" style="max-width: 500px; border-radius: 8px;">
        <form action="/editar_usuario" method="POST">
            <div class="modal-content">
                <h4 style="color: #2196F3;">✏️ Editar Usuario</h4>
                <div class="row" style="margin-top: 20px;">
                    <input type="hidden" name="id_usuario" id="id_usuario_editar">

                    <div class="input-field col s12">
                        <i class="material-icons prefix">person</i>
                        <input id="username_editar" name="username" type="text" class="validate" required>
                        <label for="username_editar">Nombre de Usuario</label>
                    </div>

                    <div class="input-field col s12">
                        <i class="material-icons prefix">lock</i>
                        <input id="password_editar" name="password" type="password" class="validate">
                        <label for="password_editar">Contraseña (Dejar vacío para no cambiar)</label>
                    </div>

                    <div class="input-field col s12">
                        <i class="material-icons prefix">assignment_ind</i>
                        <select name="rol" id="rol_editar" required>
                            <option value="" disabled>Selecciona un rol</option>
                            <option value="superadmin">Super Administrador</option>
                            <option value="admin">Administrador</option>
                            <option value="profesor">Profesor / Docente</option>
                        </select>
                        <label>Rol</label>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <a href="#!" class="modal-close waves-effect waves-red btn-flat">Cancelar</a>
                <button type="submit" class="waves-effect waves-green btn blue darken-1">Guardar Cambios</button>
            </div>
        </form>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            M.AutoInit();
        });

        function cargarUsuario(id, username, rol) {
            document.getElementById('id_usuario_editar').value = id;
            document.getElementById('username_editar').value = username;
            document.getElementById('password_editar').value = ''; 
            
            const selectRol = document.getElementById('rol_editar');
            selectRol.value = rol;

            if (typeof M !== 'undefined') {
                M.updateTextFields();
                M.FormSelect.init(selectRol);
            }
        }
    </script>
</body>

</html>
