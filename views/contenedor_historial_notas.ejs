<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Historial de Notas</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    
    <style>
        /* Tema morado institucional */
        nav { background: linear-gradient( #04144a 100%); }
        
        /* Ajuste para Tabla con Scroll y Header Fijo */
        .table-container {
            max-height: 60vh;
            overflow: auto;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            border-radius: 8px;
            margin-top: 20px;
        }
        thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        /* Colores de las notas */
        .nota-subio { color: #2e7d32; font-weight: bold; } /* Verde oscuro */
        .nota-bajo { color: #c62828; font-weight: bold; }  /* Rojo oscuro */
        .nota-antigua { color: #9e9e9e; text-decoration: line-through; }
    </style>
</head>
<body class="grey lighten-4">

    <nav>
        <div class="nav-wrapper container">
            <a href="#" class="brand-logo left hide-on-small-only" style="font-size: 1.5rem;">
                <i class="material-icons left">manage_search</i>Historial de Notas
            </a>
            <ul id="nav-mobile" class="right">
                <li><a href="/contenedor_admin"><i class="material-icons left">dashboard</i>Menú Admin</a></li>
                <li><a href="/notas"><i class="material-icons left">assessment</i>Ir a Notas</a></li>
                <li><a href="/logout" class="red darken-3 waves-effect waves-light btn"><i class="material-icons left">exit_to_app</i>Salir</a></li>
            </ul>
        </div>
    </nav>

    <div class="container" style="margin-top: 20px; width: 95%; max-width: 1400px;">
        
        <div class="card-panel">
            <h5 class="center-align" style="color: #495057; font-weight: 600;">🔍 Filtros de Búsqueda</h5>
            <div class="row" style="margin-bottom: 0;">
                
                <div class="input-field col s12 m6 l3">
                    <i class="material-icons prefix">search</i>
                    <input id="buscarAlumno" type="text" class="validate">
                    <label for="buscarAlumno">Nombre o RUT del Alumno</label>
                </div>

                <div class="input-field col s12 m6 l3">
                    <i class="material-icons prefix">class</i>
                    <select id="filtroCurso">
                        <option value="" selected>Todos los cursos</option>
                    </select>
                    <label>Filtrar por Curso</label>
                </div>

                <div class="input-field col s12 m6 l3">
                    <i class="material-icons prefix">library_books</i>
                    <select id="filtroAsignatura">
                        <option value="" selected>Todas las asignaturas</option>
                    </select>
                    <label>Filtrar por Asignatura</label>
                </div>

                <div class="input-field col s12 m6 l3">
                    <i class="material-icons prefix">person_outline</i>
                    <select id="filtroModificador">
                        <option value="" selected>Cualquier usuario</option>
                    </select>
                    <label>Modificado Por</label>
                </div>

            </div>
            <div class="row center-align" style="margin-bottom: 0;">
                <button id="btnLimpiarFiltros" class="btn-flat waves-effect waves-red grey-text text-darken-2">
                    <i class="material-icons left">clear_all</i>Limpiar Filtros
                </button>
                <button id="btnRecargarHistorial" class="btn waves-effect waves-light blue darken-2">
                    <i class="material-icons left">refresh</i>Recargar Datos
                </button>
            </div>
        </div>

        <div class="card table-container">
            <table class="highlight centered striped">
                <thead>
                    <tr>
                        <th>Fecha y Hora</th>
                        <th>Modificado Por</th>
                        <th>Alumno</th>
                        <th>RUT</th>
                        <th>Curso</th>
                        <th>Asignatura (Docente)</th>
                        <th>Evaluación</th>
                        <th>Nota Anterior</th>
                        <th>Nota Nueva</th>
                    </tr>
                </thead>
                <tbody id="tablaBodyHistorial">
                    <tr>
                        <td colspan="9" class="grey-text center-align" style="padding: 30px;">
                            <div class="preloader-wrapper small active">
                                <div class="spinner-layer spinner-blue-only">
                                  <div class="circle-clipper left"><div class="circle"></div></div>
                                  <div class="gap-patch"><div class="circle"></div></div>
                                  <div class="circle-clipper right"><div class="circle"></div></div>
                                </div>
                            </div>
                            <br>Cargando el historial...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div> 

    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            M.AutoInit(); // Inicializa los select y modales
            cargarHistorial();
        });

        // Eventos de los filtros
        document.getElementById('buscarAlumno').addEventListener('input', aplicarFiltros);
        document.getElementById('filtroCurso').addEventListener('change', aplicarFiltros);
        document.getElementById('filtroAsignatura').addEventListener('change', aplicarFiltros);
        document.getElementById('filtroModificador').addEventListener('change', aplicarFiltros);
        
        document.getElementById('btnRecargarHistorial').addEventListener('click', cargarHistorial);
        document.getElementById('btnLimpiarFiltros').addEventListener('click', () => {
            document.getElementById('buscarAlumno').value = '';
            document.getElementById('filtroCurso').value = '';
            document.getElementById('filtroAsignatura').value = '';
            document.getElementById('filtroModificador').value = '';
            M.updateTextFields(); // Arregla el label del input text
            M.FormSelect.init(document.querySelectorAll('select')); // Refresca los selects visualmente
            aplicarFiltros();
        });

        let datosHistorial = [];

        async function cargarHistorial() {
            try {
                const response = await fetch('/api/historial_notas');
                if (!response.ok) throw new Error('Error en el servidor');
                
                datosHistorial = await response.json();
                
                // Extraer opciones únicas para poblar los Selects
                poblarSelectsFiltros(datosHistorial);
                
                // Dibujar tabla
                renderizarTabla(datosHistorial);
                
            } catch (error) {
                console.error(error);
                M.toast({html: '⚠️ Error al cargar historial. Verifica consola.', classes: 'red darken-1'});
            }
        }

        function poblarSelectsFiltros(datos) {
            // Usamos Set para evitar duplicados
            const cursos = [...new Set(datos.map(d => `${d.grado}° ${d.letra_curso}`))].sort();
            const asignaturas = [...new Set(datos.map(d => d.nombre_asignatura))].sort();
            const modificadores = [...new Set(datos.map(d => d.modificado_por))].sort();

            const selectCurso = document.getElementById('filtroCurso');
            const selectAsig = document.getElementById('filtroAsignatura');
            const selectMod = document.getElementById('filtroModificador');

            // Limpiar y poblar Cursos
            selectCurso.innerHTML = '<option value="" selected>Todos los cursos</option>';
            cursos.forEach(c => selectCurso.innerHTML += `<option value="${c}">${c}</option>`);

            // Limpiar y poblar Asignaturas
            selectAsig.innerHTML = '<option value="" selected>Todas las asignaturas</option>';
            asignaturas.forEach(a => selectAsig.innerHTML += `<option value="${a}">${a}</option>`);

            // Limpiar y poblar Modificadores
            selectMod.innerHTML = '<option value="" selected>Cualquier usuario</option>';
            modificadores.forEach(m => selectMod.innerHTML += `<option value="${m}">${m}</option>`);

            // Reinicializar Selects de Materialize para que muestren los nuevos datos
            M.FormSelect.init(document.querySelectorAll('select'));
        }

        function aplicarFiltros() {
            const textoBuscado = document.getElementById('buscarAlumno').value.toLowerCase();
            const cursoSeleccionado = document.getElementById('filtroCurso').value;
            const asigSeleccionada = document.getElementById('filtroAsignatura').value;
            const modSeleccionado = document.getElementById('filtroModificador').value;
            
            const datosFiltrados = datosHistorial.filter(registro => {
                const nombreCompleto = `${registro.nombre_alumno} ${registro.apellido_alumno}`.toLowerCase();
                const rut = registro.rut_alumno.toLowerCase();
                const cursoRegistro = `${registro.grado}° ${registro.letra_curso}`;

                // Condiciones de coincidencia (Si el filtro está vacío, pasa siempre)
                const cumpleTexto = nombreCompleto.includes(textoBuscado) || rut.includes(textoBuscado);
                const cumpleCurso = cursoSeleccionado === "" || cursoRegistro === cursoSeleccionado;
                const cumpleAsig = asigSeleccionada === "" || registro.nombre_asignatura === asigSeleccionada;
                const cumpleMod = modSeleccionado === "" || registro.modificado_por === modSeleccionado;

                // Solo muestra si cumple todos los filtros activos
                return cumpleTexto && cumpleCurso && cumpleAsig && cumpleMod;
            });
            
            renderizarTabla(datosFiltrados);
        }

        function renderizarTabla(datos) {
            const tbody = document.getElementById('tablaBodyHistorial');
            tbody.innerHTML = '';

            if (datos.length === 0) {
                tbody.innerHTML = '<tr><td colspan="9" class="grey-text center-align" style="padding: 20px;">No se encontraron modificaciones con los filtros actuales.</td></tr>';
                return;
            }

            datos.forEach(registro => {
                const tr = document.createElement('tr');
                
                // Formateo de Fecha
                const fechaObj = new Date(registro.fecha_del_cambio);
                const fechaTexto = `${fechaObj.toLocaleDateString('es-CL')} <br><small class="grey-text">${fechaObj.toLocaleTimeString('es-CL', {hour: '2-digit', minute:'2-digit'})}</small>`;
                
                // Formateo de notas y lógica de colores
                const notaAnt = registro.nota_anterior !== null ? parseFloat(registro.nota_anterior).toFixed(1) : 'S/N';
                const notaNuev = parseFloat(registro.nota_nueva).toFixed(1);
                
                let claseCambio = '';
                let iconoCambio = '';
                if (registro.nota_anterior !== null) {
                    if (parseFloat(registro.nota_nueva) > parseFloat(registro.nota_anterior)) {
                        claseCambio = 'nota-subio';
                        iconoCambio = '<i class="material-icons tiny">arrow_upward</i>';
                    } else if (parseFloat(registro.nota_nueva) < parseFloat(registro.nota_anterior)) {
                        claseCambio = 'nota-bajo';
                        iconoCambio = '<i class="material-icons tiny">arrow_downward</i>';
                    }
                }

                tr.innerHTML = `
                    <td>${fechaTexto}</td>
                    <td><div class="chip"><i class="material-icons">account_circle</i> ${registro.modificado_por}</div></td>
                    <td style="font-weight: bold;">${registro.nombre_alumno} ${registro.apellido_alumno}</td>
                    <td>${registro.rut_alumno}</td>
                    <td><span class="blue-text text-darken-2" style="font-weight: bold;">${registro.grado}° ${registro.letra_curso}</span></td>
                    <td>${registro.nombre_asignatura}<br><small class="grey-text">(${registro.nombre_profesor} ${registro.apellido_profesor})</small></td>
                    <td>${registro.evaluacion}</td>
                    <td class="nota-antigua">${notaAnt}</td>
                    <td class="${claseCambio}">${iconoCambio} ${notaNuev}</td>
                `;
                tbody.appendChild(tr);
            });
        }
    </script>
</body>
</html>