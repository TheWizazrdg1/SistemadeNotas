<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión de Asignaturas</title>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    
    <style>

        #nombre_asignatura::placeholder {
        color: #060101; /* más oscuro que el gris normal */
             opacity: 1; /* evita que algunos navegadores lo vean muy claro */
            }
        /* Tema morado institucional */
        nav { background:  #04144a 100%; }
        .modal h4 { color: 04144a; }
        
        /* Ajuste para Tabla */
        .table-container {
            max-height: 60vh;
            overflow: auto;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            border-radius: 8px;
        }
        thead th {
            position: sticky;
            top: 0;
            z-index: 10;
            background:  #04144a  100%;
            color: white;
        }
    </style>
</head>
<body class="grey lighten-4">

    <nav>
        <div class="nav-wrapper container">
            <a href="/" class="brand-logo left hide-on-small-only" style="font-size: 1.5rem;">
                <i class="material-icons left">menu_book</i>Asignaturas
            </a>
            <ul id="nav-mobile" class="right">
                 <li><a href="/contenedor_admin"><i class="material-icons left">class</i>Menu</a></li>
                <li><a href="/cursos"><i class="material-icons left">class</i>Cursos</a></li>
                <li><a href="/profesores"><i class="material-icons left">assignment_ind</i>Profesores</a></li>
                <li><a href="/notas"><i class="material-icons left">assessment</i>Notas</a></li>
                <li><a href="/logout" class="red darken-3 waves-effect waves-light btn"><i class="material-icons left">exit_to_app</i>Salir</a></li>
            </ul>
        </div>
    </nav>

    <div class="container" style="margin-top: 20px; width: 95%; max-width: 1000px;">
        
        <div class="card-panel">
            <h5 class="center-align" style="color: #000000; font-weight: 600;"> Registrar Nueva Asignatura</h5>
            <form action="/crear_asignatura" method="POST" class="row" style="margin-bottom: 0;">
                
                <div class="input-field col s12 m8">
                    <i class="material-icons prefix">library_books</i>
                    <input id="nombre_asignatura" name="nombre_asignatura" type="text" class="validate"  required placeholder ="Ej: Lenguaje y Comunicación">
                    <label for="nombre_asignatura">Nombre de la Asignatura</label>
                </div>

                <div class="input-field col s12 m4 center-align">
                    <button class="btn waves-effect waves-light green darken-1" type="submit" style="width: 100%; height: 45px;">
                        Guardar
                        <i class="material-icons right">add_circle</i>
                    </button>
                </div>
            </form>
        </div>

        <div class="row mb-0">
            <div class="input-field col s12 m8 offset-m2">
                <i class="material-icons prefix">search</i>
                <input id="buscador_asignaturas" type="text" class="validate">
                <label for="buscador_asignaturas">🔍 Buscar asignatura...</label>
            </div>
        </div>

        <div class="card table-container">
            <table class="highlight centered striped">
                <thead>
                    <tr>
                        <th style="width: 20%;">ID</th>
                        <th style="width: 50%;">Nombre de la Asignatura</th>
                        <th style="width: 30%;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (asignaturas && asignaturas.length > 0) { %>
                        <% asignaturas.forEach(a => { %>
                        <tr>
                            <td class="grey-text">#<%= a.id_asignatura %></td>
                            <td style="font-weight: 500; font-size: 1.1em;"><%= a.nombre_asignatura %></td>
                            <td>
                                <a href="#modalEdicionAsignatura" 
                                   class="btn-small amber darken-2 modal-trigger waves-effect waves-light" 
                                   onclick="cargarAsignatura('<%= a.id_asignatura %>', '<%= a.nombre_asignatura %>')">
                                   <i class="material-icons">edit</i>
                                </a>
                                <a href="/borrar_asignatura/<%= a.id_asignatura %>" 
                                   class="btn-small red darken-2 waves-effect waves-light" 
                                   onclick="return confirm('¿Seguro que deseas desactivar la asignatura <%= a.nombre_asignatura %>?');">
                                   <i class="material-icons">delete</i>
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="3" class="grey-text center-align" style="padding: 20px;">
                                No hay asignaturas registradas en el sistema.
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

    </div>

    <div id="modalEdicionAsignatura" class="modal" style="max-width: 500px; border-radius: 8px;">
        <form action="/editar_asignatura" method="POST">
            <div class="modal-content">
                <h4>✏️ Editar Asignatura</h4>
                <div class="row" style="margin-top: 20px;">
                    <input type="hidden" name="id_asignatura" id="id_asignatura_editar">

                    <div class="input-field col s12">
                        <i class="material-icons prefix">library_books</i>
                        <input id="nombre_editar" name="nombre_asignatura" type="text" class="validate" required>
                        <label for="nombre_editar">Nombre de la Asignatura</label>
                    </div>
                </div>
            </div>
            
            <div class="modal-footer">
                <a href="#!" class="modal-close waves-effect waves-red btn-flat">Cancelar</a>
                <button type="submit" class="waves-effect waves-green btn blue darken-1">Guardar Cambios</button>
            </div>
        </form>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            M.AutoInit();
        });

        // Función para cargar los datos en el Modal
        function cargarAsignatura(id, nombre) {
            document.getElementById('id_asignatura_editar').value = id;
            document.getElementById('nombre_editar').value = nombre;
            M.updateTextFields();
        }

        // Buscador en tiempo real
        const inputBusqueda = document.getElementById('buscador_asignaturas');
        if (inputBusqueda) {
            inputBusqueda.addEventListener('keyup', function() {
                const texto = this.value.toLowerCase();
                const filas = document.querySelectorAll('table tbody tr');
                
                filas.forEach(fila => {
                    if(fila.cells.length === 1) return; // Ignorar fila de "No hay asignaturas"

                    const nombre = fila.cells[1].textContent.toLowerCase();
                    
                    if (nombre.includes(texto)) {
                        fila.style.display = ''; 
                    } else {
                        fila.style.display = 'none'; 
                    }
                });
            });
        }
    </script>
</body>
</html>